{
  "name": "lifting-quest-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run --outdir /tmp/out",
    "db:migrate": "wrangler d1 execute lifting-quest --remote --file=migrations/0001_init.sql",
    "db:migrate:local": "wrangler d1 execute lifting-quest --local --file=migrations/0001_init.sql"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.0.0",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.0.0"
  }
}
